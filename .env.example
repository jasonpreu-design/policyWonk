# PolicyWonk - Wonk HQ Configuration

# Database (optional, defaults to ./data/policywonk.db)
# POLICYWONK_DB_PATH=./data/policywonk.db

# Congress.gov API (free key from https://api.congress.gov/sign-up/)
CONGRESS_API_KEY=

# Daily Digest Email
DIGEST_TO_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Wonk HQ <wonkhq@policywonk.local>

# Web Server
PORT=3000
